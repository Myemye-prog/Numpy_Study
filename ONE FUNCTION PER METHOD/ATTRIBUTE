import numpy as np


def header(title):
    print("\n" + "-" * 78)
    print(title)
    print("-" * 78)


# ==============================================================================
# CATEGORY 1: ARRAY CREATION FUNCTIONS
# ==============================================================================

def f_array():
    """
    np.array()
    WHAT : Builds an ndarray from an existing Python list/tuple.
    WHY  : It's the most direct way to turn data you already have into NumPy's
           fast, contiguous-memory format.
    WHEN : Use whenever you already have raw data in a Python list/tuple/nested
           list and want NumPy's speed and vectorized operations on it.
    """
    header("f_array() -> np.array()")
    result = np.array([1, 2, 3, 4, 5])
    print("Input list  : [1, 2, 3, 4, 5]")
    print("np.array()  :", result)
    return result


def f_zeros():
    """
    np.zeros(shape)
    WHAT : Creates an array filled entirely with 0.
    WHY  : Many algorithms need a "starting point" of nothing before
           accumulating values into it (counters, sums, initial weights).
    WHEN : Use when you need a placeholder array to fill in later, e.g.
           initializing a result matrix before a loop writes into it.
    """
    header("f_zeros() -> np.zeros()")
    result = np.zeros((2, 3))
    print("np.zeros((2,3)):\n", result)
    return result


def f_ones():
    """
    np.ones(shape)
    WHAT : Creates an array filled entirely with 1.
    WHY  : Useful as a multiplicative base, or as a "mask" of all-true values.
    WHEN : Use for initializing weights, building constant matrices, or
           creating a starting mask array of all-included values.
    """
    header("f_ones() -> np.ones()")
    result = np.one((3, 3))
    print("np.ones((3,3)):\n", result)
    return result


def f_full():
    """
    np.full(shape, fill_value)
    WHAT : Creates an array of given shape filled with a CUSTOM constant.
    WHY  : zeros/ones only give 0 or 1 - sometimes you need any other constant.
    WHEN : Use when you need to pre-fill an array with a specific default,
           e.g. filling a "not yet computed" sentinel value like -1.
    """
    header("f_full() -> np.full()")
    result = np.full((2, 2), 7)
    print("np.full((2,2), 7):\n", result)
    return result


def f_empty():
    """
    np.empty(shape)
    WHAT : Allocates array memory WITHOUT initializing values (contains
           whatever garbage was already in memory).
    WHY  : Skipping initialization makes allocation slightly faster than
           zeros/ones/full.
    WHEN : Use ONLY when you will immediately overwrite every element
           yourself right after. Risky otherwise - values are unpredictable.
    """
    header("f_empty() -> np.empty()")
    result = np.empty((2, 2))
    print("np.empty((2,2)) [uninitialized/garbage values]:\n", result)
    return result


def f_arange():
    """
    np.arange(start, stop, step)
    WHAT : Creates evenly spaced values based on a STEP SIZE (like Python's
           built-in range(), but returns an ndarray and supports floats).
    WHY  : Quick way to generate sequences of numbers for indexing, loops,
           or plotting axes.
    WHEN : Use when you know the STEP SIZE you want between values.
    """
    header("f_arange() -> np.arange()")
    result = np.arange(0, 10, 2)
    print("np.arange(0, 10, 2):", result)
    return result


def f_linspace():
    """
    np.linspace(start, stop, num)
    WHAT : Creates a specific COUNT of evenly spaced values between two
           endpoints (inclusive of both ends by default).
    WHY  : Unlike arange (step-based), linspace guarantees an exact NUMBER
           of points - important when the exact count matters more than
           the gap size.
    WHEN : Use for plotting (e.g. "give me 100 x-values from 0 to 1") or any
           time you need N samples spanning a range exactly.
    """
    header("f_linspace() -> np.linspace()")
    result = np.linspace(0, 1, 5)
    print("np.linspace(0, 1, 5):", result)
    return result


def f_eye():
    """
    np.eye(n)
    WHAT : Creates an n x n identity matrix (1s on the diagonal, 0 elsewhere).
    WHY  : The identity matrix is the "do nothing" element for matrix
           multiplication (like the number 1 for regular multiplication).
    WHEN : Use in linear algebra - solving equations, initializing
           transformation matrices, testing matrix inverses.
    """
    header("f_eye() -> np.eye()")
    result = np.eye(4)
    print("np.eye(4):\n", result)
    return result


def f_diag():
    """
    np.diag(values)
    WHAT : Builds a matrix with the given values on the diagonal (rest zero).
           If given a 2D matrix instead, it EXTRACTS the diagonal values.
    WHY  : Diagonal matrices are common in linear algebra (e.g. scaling
           transforms, covariance matrices).
    WHEN : Use to build a diagonal matrix from a list, OR to pull out just
           the diagonal elements of an existing matrix.
    """
    header("f_diag() -> np.diag()")
    result = np.diag([1, 2, 3])
    print("np.diag([1,2,3]) -> build matrix:\n", result)
    extracted = np.diag(result)
    print("np.diag(matrix) -> extract diagonal:", extracted)
    return result


def f_random_rand():
    """
    np.random.rand(shape)
    WHAT : Generates random floats uniformly distributed in [0, 1).
    WHY  : Uniform randomness is needed for simulations, random sampling,
           shuffling, or initializing values with no particular bias.
    WHEN : Use when every value in the range should be equally likely
           (e.g. randomly initializing probabilities, dropout masks).
    """
    header("f_random_rand() -> np.random.rand()")
    np.random.seed(42)
    result = np.random.rand(2, 2)
    print("np.random.rand(2,2):\n", result)
    return result


def f_random_randn():
    """
    np.random.randn(shape)
    WHAT : Generates random floats from a STANDARD NORMAL (Gaussian, mean=0,
           std=1) distribution.
    WHY  : Many real-world phenomena (noise, errors, natural variation)
           follow a normal distribution, not a uniform one.
    WHEN : Use when initializing neural network weights, simulating natural
           noise, or generating test data that should cluster around a mean.
    """
    header("f_random_randn() -> np.random.randn()")
    np.random.seed(42)
    result = np.random.randn(2, 2)
    print("np.random.randn(2,2):\n", result)
    return result


def f_random_randint():
    """
    np.random.randint(low, high, size)
    WHAT : Generates random INTEGERS in the range [low, high).
    WHY  : Uniform random floats aren't useful when you need whole numbers
           (e.g. dice rolls, random indices, categorical labels).
    WHEN : Use for simulating discrete random events or picking random
           indices/categories.
    """
    header("f_random_randint() -> np.random.randint()")
    np.random.seed(42)
    result = np.random.randint(0, 10, (2, 3))
    print("np.random.randint(0, 10, (2,3)):\n", result)
    return result


def f_zeros_like():
    """
    np.zeros_like(existing_array)
    WHAT : Creates a new zero-filled array with the SAME shape and dtype as
           an existing array.
    WHY  : Saves you from manually reading .shape and .dtype and typing them
           into np.zeros() yourself - less error-prone.
    WHEN : Use when you need a "blank slate" that must exactly match another
           array's shape (e.g. an accumulator matching your data's shape).
    """
    header("f_zeros_like() -> np.zeros_like()")
    original = np.array([[1, 2], [3, 4]])
    result = np.zeros_like(original)
    print("original:\n", original)
    print("np.zeros_like(original):\n", result)
    return result


