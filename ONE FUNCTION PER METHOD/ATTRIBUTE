def f_save_load_npy():
    """
    np.save() / np.load()
    WHAT : Writes a single array to disk in NumPy's own fast binary format
           (.npy), and reads it back exactly as it was.
    WHY  : Exact, lossless, and fast round-tripping of array data - far
           quicker than re-parsing text on every load.
    WHEN : Use when you need to persist array data between Python program
           runs and don't need the file to be human-readable.
    """
    header("f_save_load_npy() -> np.save() / np.load()")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    np.save("/tmp/demo_array.npy", arr)
    loaded = np.load("/tmp/demo_array.npy")
    print("saved array:\n", arr)
    print("loaded back from .npy:\n", loaded)
    return loaded


def f_savez():
    """
    np.savez() / np.load() for multiple arrays
    WHAT : Saves MULTIPLE named arrays together into a single .npz file
           (a zipped archive of .npy files).
    WHY  : Keeps related arrays bundled in one file instead of managing
           several separate files.
    WHEN : Use when a single "session" or "result set" involves multiple
           arrays that belong together (e.g. training data + labels).
    """
    header("f_savez() -> np.savez()")
    a = np.array([1, 2, 3])
    b = np.array([4, 5, 6])
    np.savez("/tmp/demo_multi.npz", features=a, labels=b)
    loaded = np.load("/tmp/demo_multi.npz")
    print("saved arrays under keys:", list(loaded.keys()))
    print("loaded['features']:", loaded["features"])
    print("loaded['labels']  :", loaded["labels"])
    return loaded


def f_savetxt_loadtxt():
    """
    np.savetxt() / np.loadtxt()
    WHAT : Saves/loads an array as human-readable plain text (e.g. CSV).
    WHY  : Unlike .npy (binary), text files can be opened in Excel, viewed
           in a text editor, or shared with tools that don't use NumPy.
    WHEN : Use when the file needs to be human-readable or compatible with
           other software (spreadsheets, other programming languages).
    """
    header("f_savetxt_loadtxt() -> np.savetxt() / np.loadtxt()")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    np.savetxt("/tmp/demo_array.csv", arr, delimiter=",", fmt="%d")
    loaded = np.loadtxt("/tmp/demo_array.csv", delimiter=",")
    print("saved as CSV, loaded back:\n", loaded)
    return loaded


