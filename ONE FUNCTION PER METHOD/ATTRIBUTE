def f_det():
    """
    np.linalg.det(matrix)
    WHAT : Computes the determinant of a square matrix (a single number
           summarizing certain matrix properties).
    WHY  : A determinant of 0 means the matrix is "singular" (not
           invertible) - critical to know before trying to solve equations.
    WHEN : Use to check if a matrix can be inverted, or in formulas from
           geometry/calculus that require the determinant (e.g. Jacobians).
    """
    header("f_det() -> np.linalg.det()")
    A = np.array([[1, 2], [3, 4]])
    print("A:\n", A)
    print("np.linalg.det(A):", np.linalg.det(A))
    return np.linalg.det(A)


def f_inv():
    """
    np.linalg.inv(matrix)
    WHAT : Computes the inverse of a square matrix (the matrix that
           "undoes" the original when multiplied together).
    WHY  : Needed to algebraically "divide" by a matrix, e.g. solving
           systems of linear equations or reversing a transformation.
    WHEN : Use when solving Ax=b problems manually, or reversing a linear
           transformation (though np.linalg.solve is often more efficient).
    """
    header("f_inv() -> np.linalg.inv()")
    A = np.array([[4, 7], [2, 6]])
    inv_A = np.linalg.inv(A)
    print("A:\n", A)
    print("np.linalg.inv(A):\n", inv_A)
    print("Check: A @ inv(A) ≈ Identity:\n", np.round(A @ inv_A, 5))
    return inv_A


def f_solve():
    """
    np.linalg.solve(A, b)
    WHAT : Solves the linear system Ax = b directly for x.
    WHY  : Faster and numerically more stable than manually computing
           inv(A) @ b - avoids unnecessary precision loss.
    WHEN : Use whenever you have a system of linear equations to solve,
           e.g. balancing chemical equations, circuit analysis, regression.
    """
    header("f_solve() -> np.linalg.solve()")
    A = np.array([[3, 1], [1, 2]])
    b = np.array([9, 8])
    x = np.linalg.solve(A, b)
    print("Solving Ax=b for A:\n", A, "\nb:", b)
    print("x =", x)
    return x


def f_norm():
    """
    np.linalg.norm(vector)
    WHAT : Computes the magnitude/length of a vector (Euclidean norm by
           default).
    WHY  : "Distance" and "magnitude" show up everywhere - physics,
           machine learning (loss functions), computer graphics.
    WHEN : Use to measure how "big" a vector is, or to compute distances
           between two points (norm of their difference).
    """
    header("f_norm() -> np.linalg.norm()")
    v = np.array([3, 4])
    print("vector:", v)
    print("np.linalg.norm(v):", np.linalg.norm(v), "-> classic 3-4-5 triangle, length = 5")
    return np.linalg.norm(v)


def f_eig():
    """
    np.linalg.eig(matrix)
    WHAT : Computes the eigenvalues and eigenvectors of a square matrix.
    WHY  : Eigenvalues/vectors reveal a matrix's fundamental "directions"
           and "scaling factors" - central to PCA, stability analysis,
           and vibration/oscillation problems.
    WHEN : Use in dimensionality reduction (PCA), analyzing dynamic systems,
           or any problem asking about a matrix's intrinsic structure.
    """
    header("f_eig() -> np.linalg.eig()")
    A = np.array([[2, 0], [0, 3]])
    eigenvalues, eigenvectors = np.linalg.eig(A)
    print("A:\n", A)
    print("eigenvalues :", eigenvalues)
    print("eigenvectors:\n", eigenvectors)
    return eigenvalues, eigenvectors


