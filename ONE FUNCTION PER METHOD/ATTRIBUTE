def f_basic_slicing():
    """
    arr[start:stop:step] / arr[row, col]
    WHAT : Selects a contiguous range or single element using start:stop:step
           syntax (same idea as Python list slicing, but works per-axis).
    WHY  : The most common and fastest way to grab a sub-section of data.
    WHEN : Use when the elements you want are CONTIGUOUS (a range of rows,
           columns, or a rectangular block).
    """
    header("f_basic_slicing() -> arr[start:stop:step]")
    arr = np.arange(1, 26).reshape(5, 5)
    print("arr:\n", arr)
    print("arr[1, 2]      :", arr[1, 2], "-> single element at row 1, col 2")
    print("arr[1]         :", arr[1], "-> entire row 1")
    print("arr[:, 2]      :", arr[:, 2], "-> entire column 2")
    print("arr[1:3, 2:4]  :\n", arr[1:3, 2:4], "-> rectangular block")
    return arr[1:3, 2:4]


def f_fancy_indexing():
    """
    arr[[i, j, k]]
    WHAT : Selects elements using a LIST/array of indices, which need not
           be contiguous or in order.
    WHY  : Basic slicing can only grab contiguous ranges - fancy indexing
           lets you grab any arbitrary combination of positions.
    WHEN : Use when you need SPECIFIC, non-contiguous rows/columns/elements,
           e.g. selecting rows [0, 5, 10] out of a large dataset.
    """
    header("f_fancy_indexing() -> arr[[i,j,k]]")
    arr = np.arange(1, 26).reshape(5, 5)
    idx = [0, 2, 4]
    print("arr:\n", arr)
    print("arr[[0,2,4]] (non-contiguous rows):\n", arr[idx])
    return arr[idx]


def f_boolean_indexing():
    """
    arr[condition]
    WHAT : Selects only the elements where a boolean condition is True.
    WHY  : Lets you filter data based on VALUE rather than position -
           essential for real-world data cleaning/filtering.
    WHEN : Use whenever you need "give me all values that satisfy X",
           e.g. all values greater than a threshold, or all non-null entries.
    """
    header("f_boolean_indexing() -> arr[condition]")
    arr = np.arange(1, 11)
    print("arr:", arr)
    mask = arr % 2 == 0
    print("mask (arr % 2 == 0):", mask)
    result = arr[mask]
    print("arr[mask] (even numbers only):", result)
    return result


