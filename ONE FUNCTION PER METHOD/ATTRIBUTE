def f_sum():
    """
    arr.sum(axis=None)
    WHAT : Adds up all elements, or all elements ALONG a specific axis.
    WHY  : Totaling values is one of the most common data operations
           (revenue totals, counts, accumulations).
    WHEN : Use axis=0 to sum DOWN columns, axis=1 to sum ACROSS rows, or no
           axis for a single grand total.
    """
    header("f_sum() -> arr.sum()")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    print("arr:\n", arr)
