def f_mean():
    """
    arr.mean(axis=None)
    WHAT : Computes the average value.
    WHY  : The standard way to describe the "center" of a dataset.
    WHEN : Use to summarize typical values - but be aware it's sensitive
           to outliers (a few huge values can skew it).
    """
    header("f_mean() -> arr.mean()")
    arr = np.array([1, 2, 3, 4, 100])
    print("arr:", arr)
    print("arr.mean():", arr.mean(), "-> pulled upward by the outlier 100")
    return arr.mean()


def f_median():
    """
    np.median(arr)
    WHAT : Computes the middle value when data is sorted.
    WHY  : Unlike mean, median is ROBUST to outliers - a few extreme values
           don't drag it far from the "typical" value.
    WHEN : Use instead of mean when your data has outliers or skew
           (e.g. household income, response times).
    """
    header("f_median() -> np.median()")
    arr = np.array([1, 2, 3, 4, 100])
    print("arr:", arr)
    print("np.median(arr):", np.median(arr), "-> unaffected by the outlier 100, unlike mean")
    return np.median(arr)


def f_std():
    """
    arr.std()
    WHAT : Computes the standard deviation - how spread out values are
           around the mean.
    WHY  : A single sum or mean doesn't tell you if data is tightly
           clustered or widely scattered - std captures that.
    WHEN : Use when measuring consistency/variability, e.g. checking if
           a manufacturing process is stable, or comparing risk in finance.
    """
    header("f_std() -> arr.std()")
    tight = np.array([9, 10, 11])
    spread = np.array([0, 10, 20])
