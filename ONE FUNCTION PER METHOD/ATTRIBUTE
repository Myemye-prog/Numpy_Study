def f_sort():
    """
    np.sort(arr) / arr.sort()
    WHAT : np.sort(arr) returns a SORTED COPY; arr.sort() sorts IN-PLACE.
    WHY  : Ordering data is fundamental for ranking, reporting, and
           preparing data for algorithms that require sorted input.
    WHEN : Use np.sort() when you need the original preserved; use
           arr.sort() when you're fine mutating the original (saves memory).
    """
    header("f_sort() -> np.sort() / arr.sort()")
    arr = np.array([3, 1, 4, 1, 5, 9, 2, 6])
    print("original      :", arr)
    print("np.sort(arr)  :", np.sort(arr), "(copy, original untouched)")
    arr.sort()
    print("arr.sort()    :", arr, "(in-place, original changed)")
    return arr


def f_argsort():
    """
    np.argsort(arr)
    WHAT : Returns the INDICES that WOULD sort the array, rather than the
           sorted values themselves.
    WHY  : Lets you sort one array based on another - e.g. sort names by
           their corresponding scores while keeping the pairing intact.
    WHEN : Use when you need to reorder related data together (e.g. sort a
           list of names using the indices from sorting their scores).
    """
    header("f_argsort() -> np.argsort()")
    scores = np.array([85, 60, 95, 70])
    names = np.array(["Alice", "Bob", "Cara", "Dan"])
    order = np.argsort(scores)
    print("scores:", scores)
    print("argsort indices:", order)
    print("names sorted by score:", names[order])
    return order


def f_where():
    """
    np.where(condition, a, b)
    WHAT : Two modes - (1) np.where(condition) returns INDICES where True;
           (2) np.where(condition, a, b) picks from `a` where True, `b`
           where False (vectorized if/else).
    WHY  : Replaces slow Python if/else loops with a single fast vectorized
           operation.
    WHEN : Use for conditional value replacement across an entire array at
           once, e.g. capping outliers, categorizing values, masking data.
    """
    header("f_where() -> np.where()")
    arr = np.array([1, -2, 3, -4, 5])
    print("arr:", arr)
    print("np.where(arr<0)        :", np.where(arr < 0), "-> indices where condition is True")
    print("np.where(arr<0,0,arr)  :", np.where(arr < 0, 0, arr), "-> vectorized if/else: negatives replaced with 0")
    return np.where(arr < 0, 0, arr)


def f_nonzero():
    """
    np.nonzero(arr)
    WHAT : Returns the indices of all non-zero (or True) elements.
    WHY  : A quick way to locate "active"/"true"/"present" entries without
           writing a manual loop.
    WHEN : Use when you need positions of non-zero/True values, e.g.
           finding which pixels are lit in a mostly-black image mask.
    """
    header("f_nonzero() -> np.nonzero()")
    arr = np.array([0, 3, 0, 0, 7, 5])
    print("arr:", arr)
    print("np.nonzero(arr):", np.nonzero(arr), "-> indices of non-zero elements")
    return np.nonzero(arr)


def f_searchsorted():
    """
    np.searchsorted(sorted_arr, value)
    WHAT : Finds the index where `value` should be INSERTED to keep a
           SORTED array still sorted (binary search - very fast).
    WHY  : Way faster than a linear scan for finding insertion points in
           large sorted datasets (O(log n) instead of O(n)).
    WHEN : Use when working with sorted data and needing to find where new
           values fit, e.g. binning values into sorted ranges.
    """
    header("f_searchsorted() -> np.searchsorted()")
    sorted_arr = np.array([1, 3, 5, 7, 9])
    print("sorted_arr:", sorted_arr)
    idx = np.searchsorted(sorted_arr, 6)
    print("np.searchsorted(sorted_arr, 6):", idx, "-> 6 should be inserted at index", idx, "to keep it sorted")
    return idx


