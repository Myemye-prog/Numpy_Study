def f_ndim():
    """
    arr.ndim
    WHAT : Returns the number of dimensions (axes) of the array.
    WHY  : Code that processes arrays often needs to know whether it's
           handling a 1D vector, 2D matrix, or higher-dimensional tensor.
    WHEN : Use for validation/debugging - e.g. asserting a function received
           a 2D matrix and not accidentally a 1D vector.
    """
    header("f_ndim() -> arr.ndim")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    print("arr:\n", arr)
    print("arr.ndim:", arr.ndim, "-> 2 axes (rows and columns)")
    return arr.ndim


def f_shape():
    """
    arr.shape
    WHAT : Returns a tuple giving the size along each dimension.
    WHY  : The single most commonly checked attribute - almost every bug in
           array code traces back to a shape mismatch.
    WHEN : Use constantly, especially before matrix multiplication,
           broadcasting, or reshaping, to confirm shapes line up.
    """
    header("f_shape() -> arr.shape")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    print("arr:\n", arr)
    print("arr.shape:", arr.shape, "-> 2 rows, 3 columns")
    return arr.shape


def f_size():
    """
    arr.size
    WHAT : Returns the TOTAL number of elements (product of all dimensions).
    WHY  : Useful for quick sanity checks (e.g. confirming reshape math will
           work, since reshape requires the same total element count).
    WHEN : Use when you need a single number for "how much data is here",
           e.g. before allocating memory or looping.
    """
    header("f_size() -> arr.size")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    print("arr:\n", arr)
    print("arr.size:", arr.size, "-> 2*3 = 6 total elements")
    return arr.size


def f_dtype():
    """
    arr.dtype
    WHAT : Returns the data type of the array's elements (e.g. int64,
           float32, bool).
    WHY  : NumPy arrays are FIXED-TYPE (unlike Python lists) - knowing the
           dtype tells you precision, memory usage, and what operations
           are valid.
    WHEN : Use when debugging unexpected results (e.g. integer division
           truncation) or when memory/precision matters.
    """
    header("f_dtype() -> arr.dtype")
    arr = np.array([1, 2, 3])
    arr_float = np.array([1.0, 2.0, 3.0])
    print("np.array([1,2,3]).dtype       :", arr.dtype)
    print("np.array([1.0,2.0,3.0]).dtype :", arr_float.dtype)
    return arr.dtype


def f_itemsize():
    """
    arr.itemsize
    WHAT : Returns the number of BYTES used by a single element.
    WHY  : Helps you understand and control memory footprint at the
           per-element level, especially when choosing dtypes.
    WHEN : Use when optimizing memory for large arrays (e.g. choosing
           int8 vs int64 for millions of rows).
    """
    header("f_itemsize() -> arr.itemsize")
    arr_int8 = np.array([1, 2, 3], dtype=np.int8)
    arr_int64 = np.array([1, 2, 3], dtype=np.int64)
    print("int8  itemsize:", arr_int8.itemsize, "bytes per element")
    print("int64 itemsize:", arr_int64.itemsize, "bytes per element")
    return arr_int64.itemsize


def f_nbytes():
    """
    arr.nbytes
    WHAT : Returns the TOTAL bytes consumed by all elements (itemsize * size).
    WHY  : Gives you the real memory cost of an array, which matters a lot
           for big datasets (images, ML data, etc.).
    WHEN : Use when checking if a dataset will fit in available RAM before
           loading it entirely, or comparing dtype memory trade-offs.
    """
    header("f_nbytes() -> arr.nbytes")
    arr = np.zeros((1000, 1000), dtype=np.float64)
    print("Array shape:", arr.shape, "dtype:", arr.dtype)
    print("arr.nbytes:", arr.nbytes, "bytes (~", arr.nbytes / 1e6, "MB )")
    return arr.nbytes


def f_T():
    """
    arr.T
    WHAT : Returns the TRANSPOSE of the array (rows become columns).
    WHY  : Many linear algebra operations require swapping row/column
           orientation (e.g. matching shapes for matrix multiplication).
    WHEN : Use when you need to flip a matrix's orientation, e.g. converting
           a row vector to a column vector, or aligning shapes for @ (matmul).
    """
    header("f_T() -> arr.T")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    print("arr:\n", arr)
    print("arr.T (transposed):\n", arr.T)
    return arr.T


def f_flat():
    """
    arr.flat
    WHAT : Returns a 1D ITERATOR over all elements, regardless of the
           array's actual dimensionality.
    WHY  : Sometimes you just want to loop through every value once,
           without caring about the original shape.
    WHEN : Use when you need simple element-by-element iteration over an
           N-dimensional array without manually nesting loops.
    """
    header("f_flat() -> arr.flat")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    print("arr:\n", arr)
    result = list(arr.flat)
    print("list(arr.flat):", result, "-> iterates all elements as if 1D")
    return result


def f_flags():
    """
    arr.flags
    WHAT : Returns memory-layout metadata: whether the array is C-contiguous,
           Fortran-contiguous, owns its own data, and is writeable.
    WHY  : Some low-level operations (interfacing with C libraries, certain
           performance optimizations) need contiguous memory to work fast.
    WHEN : Use when debugging performance issues or interfacing NumPy with
           other libraries that require specific memory layouts.
    """
    header("f_flags() -> arr.flags")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    print("arr.flags:\n", arr.flags)
    return arr.flags


def f_base():
    """
    arr.base
    WHAT : Returns the original array this array is a VIEW of (or None if
           this array owns its own data / is not a view).
    WHY  : Helps you determine whether modifying this array will silently
           affect another array that shares its memory.
    WHEN : Use when debugging unexpected "the original data changed!" bugs
           caused by views sharing memory (see the copy-vs-view section).
    """
    header("f_base() -> arr.base")
    original = np.array([1, 2, 3, 4, 5])
    view = original[1:4]
    print("original.base:", original.base, "-> None means it owns its data")
    print("view.base is original:", view.base is original, "-> True means view shares memory with original")
    return view.base


