def f_copy():
    """
    arr.copy()
    WHAT : Creates a fully INDEPENDENT copy of an array's data in new memory.
    WHY  : Slicing/reshaping often returns a VIEW that shares memory with
           the original - modifying a view silently changes the original
           too, which causes subtle bugs. copy() prevents that.
    WHEN : Use whenever you need to modify a subset of data WITHOUT
           affecting the original array it came from.
    """
    header("f_copy() -> arr.copy()")
    original = np.array([1, 2, 3, 4, 5])
    safe_copy = original[1:4].copy()
    safe_copy[0] = 999
    print("original (untouched):", original)
    print("safe_copy (modified):", safe_copy)
    return safe_copy


def f_view_behavior():
    """
    arr[slice]  (implicitly returns a VIEW, not a copy)
    WHAT : Basic slicing returns a VIEW - a window into the SAME memory as
           the original array, not new memory.
    WHY  : Views are fast and memory-efficient (no copying), but this means
           changes to a view affect the original array too - a very common
           source of confusing bugs for NumPy beginners.
    WHEN : Rely on this behavior when you WANT changes to propagate back
           (e.g. modifying part of a big array in place); otherwise, call
           .copy() explicitly.
    """
    header("f_view_behavior() -> slicing returns a view")
    original = np.array([1, 2, 3, 4, 5])
    view = original[1:4]
    print("original before:", original)
    view[0] = 999
    print("original AFTER modifying the view:", original, "-> changed! views share memory")
    return view


