def f_reshape():
    """
    arr.reshape(new_shape)
    WHAT : Returns the SAME data rearranged into a new shape (total element
           count must stay the same).
    WHY  : Data commonly arrives flat (e.g. a list of numbers) but algorithms
           need it structured as a matrix/tensor.
    WHEN : Use whenever the shape you have doesn't match the shape you need
           for the next computation. Use -1 for a dimension to auto-calculate.
    """
    header("f_reshape() -> arr.reshape()")
    arr = np.arange(12)
    print("original:", arr)
    result = arr.reshape(3, 4)
    print("reshape(3,4):\n", result)
    return result


def f_flatten():
    """
    arr.flatten()
    WHAT : Returns a 1D COPY of the array (fully independent memory).
    WHY  : Sometimes you need a flat 1D version but must be free to modify
           it without affecting the original multi-dimensional array.
    WHEN : Use when you need a safe, independent 1D copy - e.g. before
           passing to a function that might mutate its input.
    """
    header("f_flatten() -> arr.flatten()")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    result = arr.flatten()
    result[0] = 999
    print("original (unaffected by change to flatten copy):\n", arr)
    print("flattened copy (modified):", result)
    return result


def f_ravel():
    """
    arr.ravel()
    WHAT : Returns a 1D VIEW of the array whenever possible (no memory copy).
    WHY  : Much faster than flatten() because it avoids copying data -
           but that means changes can propagate back to the original.
    WHEN : Use when you need a 1D version quickly and don't need it to be
           independent from the source array.
    """
    header("f_ravel() -> arr.ravel()")
    arr = np.array([[1, 2, 3], [4, 5, 6]])
    result = arr.ravel()
    result[0] = 999
    print("original (CHANGED because ravel is a view):\n", arr)
    print("raveled view:", result)
    return result


def f_transpose():
    """
    np.transpose(arr, axes)
    WHAT : Permutes an array's axes in any order you specify (generalizes
           .T, which only reverses all axes).
    WHY  : For 3D+ arrays (e.g. image batches: [batch, height, width]),
           you often need to reorder axes in a specific, non-reversed way.
    WHEN : Use for tensors with 3+ dimensions where simple .T isn't enough
           (e.g. converting between "channels-first" and "channels-last").
    """
    header("f_transpose() -> np.transpose()")
    arr = np.arange(24).reshape(2, 3, 4)
    print("original shape:", arr.shape)
    result = np.transpose(arr, axes=(1, 0, 2))
    print("transposed shape (axes swapped 0<->1):", result.shape)
    return result


def f_swapaxes():
    """
    np.swapaxes(arr, axis1, axis2)
    WHAT : Swaps exactly TWO specified axes, leaving others untouched.
    WHY  : Simpler and more explicit than transpose() when you only need
           to swap two particular axes (e.g. rows/cols of one sub-tensor).
    WHEN : Use for quick two-axis swaps, common in image/tensor processing.
    """
    header("f_swapaxes() -> np.swapaxes()")
    arr = np.arange(12).reshape(3, 4)
    print("original:\n", arr)
    result = np.swapaxes(arr, 0, 1)
    print("swapaxes(0,1):\n", result)
    return result


def f_resize():
    """
    arr.resize(new_shape)
    WHAT : Changes the array's shape IN-PLACE, and unlike reshape(), it CAN
           change the total number of elements (padding with 0s or
           truncating as needed).
    WHY  : reshape() requires matching element counts; resize() doesn't -
           useful when you need to grow/shrink an array's total size.
    WHEN : Use when you want to permanently resize an array in memory,
           accepting that data may be truncated or zero-padded.
    """
    header("f_resize() -> arr.resize()")
    arr = np.array([1, 2, 3, 4])
    print("original:", arr)
    arr.resize(2, 3)
    print("after resize(2,3) [padded with 0]:\n", arr)
    return arr


def f_concatenate():
    """
    np.concatenate([arr1, arr2], axis)
    WHAT : Joins a sequence of arrays along an EXISTING axis.
    WHY  : Combining datasets collected separately (e.g. batches, or rows
           from multiple sources) into a single array is a very common need.
    WHEN : Use when arrays already share the same number of dimensions and
           you just need to extend one axis (e.g. adding more rows).
    """
    header("f_concatenate() -> np.concatenate()")
    a = np.array([1, 2, 3])
    b = np.array([4, 5, 6])
    result = np.concatenate([a, b])
    print("concatenate([1,2,3],[4,5,6]):", result)
    return result


def f_stack():
    """
    np.stack([arr1, arr2], axis)
    WHAT : Joins arrays along a NEW axis, increasing dimensionality by 1.
    WHY  : Unlike concatenate (which extends an existing axis), stack
           creates a new dimension - useful for grouping equal-shaped
           arrays as a "batch".
    WHEN : Use when combining several same-shaped arrays into one higher
           dimensional array, e.g. stacking multiple images into a batch.
    """
    header("f_stack() -> np.stack()")
    a = np.array([1, 2, 3])
    b = np.array([4, 5, 6])
    result = np.stack([a, b])
    print("stack([1,2,3],[4,5,6]):\n", result, "shape:", result.shape)
    return result


def f_vstack():
    """
    np.vstack([arr1, arr2])
    WHAT : Stacks arrays vertically (row-wise), producing more rows.
    WHY  : Common shorthand for combining 1D arrays into a 2D matrix, or
           adding new rows to an existing matrix.
    WHEN : Use when you want each input array to become a ROW in the result.
    """
    header("f_vstack() -> np.vstack()")
    a = np.array([1, 2, 3])
    b = np.array([4, 5, 6])
    result = np.vstack([a, b])
    print("vstack([1,2,3],[4,5,6]):\n", result)
    return result


def f_hstack():
    """
    np.hstack([arr1, arr2])
    WHAT : Stacks arrays horizontally (side by side / column-wise for 2D).
    WHY  : Common shorthand for extending an array's width, or joining
           1D arrays end-to-end.
    WHEN : Use when you want arrays joined along their length/width rather
           than stacked as new rows.
    """
    header("f_hstack() -> np.hstack()")
    a = np.array([1, 2, 3])
    b = np.array([4, 5, 6])
    result = np.hstack([a, b])
    print("hstack([1,2,3],[4,5,6]):", result)
    return result


def f_split():
    """
    np.split(arr, n)
    WHAT : Divides an array into n EQUAL-sized parts (raises an error if it
           can't split evenly).
    WHY  : Useful for breaking a dataset into equal batches/folds/chunks.
    WHEN : Use when you know the array divides evenly into the number of
           parts you want (e.g. splitting data into k equal folds).
    """
    header("f_split() -> np.split()")
    arr = np.arange(9)
    result = np.split(arr, 3)
    print("np.split(arange(9), 3):", result)
    return result


def f_expand_dims():
    """
    np.expand_dims(arr, axis)
    WHAT : Inserts a new axis of size 1 at the given position.
    WHY  : Many APIs (especially ML frameworks) expect a specific number of
           dimensions, e.g. a "batch" dimension even for a single sample.
    WHEN : Use when a function expects more dimensions than your data
           currently has, e.g. turning a single image into a "batch of 1".
    """
    header("f_expand_dims() -> np.expand_dims()")
    arr = np.array([1, 2, 3])
    result = np.expand_dims(arr, axis=0)
    print("original shape:", arr.shape, "-> after expand_dims(axis=0):", result.shape)
    return result


def f_squeeze():
    """
    arr.squeeze()
    WHAT : Removes all dimensions of size 1 from an array's shape.
    WHY  : Extra size-1 dimensions (often left over from earlier operations)
           can clutter shapes and complicate downstream code.
    WHEN : Use to clean up an array's shape after operations that leave
           behind unnecessary size-1 axes.
    """
    header("f_squeeze() -> arr.squeeze()")
    arr = np.array([[[1, 2, 3]]])
    print("original shape:", arr.shape)
    result = arr.squeeze()
    print("after squeeze() shape:", result.shape, "value:", result)
    return result


