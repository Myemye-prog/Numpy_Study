# 11. COPY vs VIEW (a common source of bugs!)
# ==============================================================================
section("11. COPY vs VIEW")
"""
WHAT: A VIEW shares memory with the original array (changes affect both).
      A COPY is fully independent memory.
WHY:  Views are memory-efficient and fast, but can cause SURPRISING bugs
      if you think you have independent data and you don't.
WHEN: Use view (slicing, reshape, ravel) when you want speed and don't
      need independence. Use .copy() explicitly when you need to modify
      data safely without touching the original.
"""

original = np.array([1, 2, 3, 4, 5])
view = original[1:4]          # slicing creates a VIEW
copy = original[1:4].copy()   # .copy() forces independent memory

view[0] = 999
print("After modifying view, original also changes:", original, "-> view shares memory!")

original2 = np.array([1, 2, 3, 4, 5])
copy2 = original2[1:4].copy()
copy2[0] = 999
print("After modifying copy, original is untouched :", original2, "-> copy is independent")

print("\narr.base is None means it OWNS its data (not a view):")
print("original.base :", original.base)
print("view.base     :", view.base is original, "-> True means 'view' is indeed a view of 'original'")


