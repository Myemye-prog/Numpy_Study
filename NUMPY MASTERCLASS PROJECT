# ==============================================================================
# 1. WHY NUMPY EXISTS
# ==============================================================================
section("1. WHY NUMPY? (Python lists vs NumPy arrays)")
"""
WHAT: NumPy (Numerical Python) gives us the `ndarray` — a fixed-type,
      contiguous-memory array object.
WHY:  Python lists are flexible but slow and memory-heavy because each
      element is a separate Python object (with type info, ref count, etc.).
      NumPy stores raw numbers in one contiguous memory block and operates
      on them using pre-compiled C code -> 10x-100x faster, less memory.
WHEN: Use NumPy whenever you deal with numeric/scientific data, math,
      statistics, image/signal processing, ML, or any bulk numeric
      computation instead of Python `for` loops over lists.
"""

py_list = list(range(1_000_000))
np_array = np.arange(1_000_000)

import time
t0 = time.time()
py_result = [x * 2 for x in py_list]
t1 = time.time()
np_result = np_array * 2
t2 = time.time()

print(f"Pure Python list comprehension time: {t1 - t0:.5f} sec")
print(f"NumPy vectorized operation time   : {t2 - t1:.5f} sec")
print("-> NumPy wins because it uses vectorization (SIMD/C loops), not Python loops.")


