section("7. STATISTICAL / AGGREGATE METHODS")
"""
WHAT: Reduce an array to summary statistics (whole array or along an axis).
WHY:  Core of data analysis - understanding data through summaries.
WHEN: EDA (exploratory data analysis), normalizing data, comparing datasets.
      Use `axis` parameter to control ROW-wise (axis=1) vs COLUMN-wise (axis=0).
"""

data = np.array([[1, 2, 3], [4, 5, 6]])
print("data:\n", data)

print("\nsum()        :", data.sum(), "-> total of all elements")
print("sum(axis=0)  :", data.sum(axis=0), "-> WHEN summing DOWN each column")
print("sum(axis=1)  :", data.sum(axis=1), "-> WHEN summing ACROSS each row")
print("mean()       :", data.mean(), "-> average value, WHEN measuring central tendency")
print("median()     :", np.median(data), "-> WHEN data has outliers (median is robust, mean is not)")
print("std()        :", data.std(), "-> standard deviation, WHEN measuring spread/variability")
print("var()        :", data.var(), "-> variance (std squared)")
print("min() / max():", data.min(), "/", data.max(), "-> WHEN finding extremes")
print("argmin()/argmax():", data.argmin(), "/", data.argmax(), "-> WHEN you need the INDEX of the extreme, not the value")
print("cumsum()     :", data.cumsum(), "-> running total, WHEN tracking cumulative growth (e.g. running balance)")
print("cumprod()    :", data.cumprod(), "-> running product, WHEN compounding values (e.g. compound interest)")
print("np.percentile(data,90):", np.percentile(data, 90), "-> WHEN you need a specific percentile (e.g. SLA/latency p90)")
print("np.ptp(data) :", np.ptp(data), "-> peak-to-peak (max-min), WHEN measuring range quickly")
print("all() any()  :", (data > 0).all(), (data > 5).any(), "-> WHEN checking if ALL/ANY elements satisfy a condition")
print("np.unique()  :", np.unique(np.array([1, 1, 2, 2, 3])), "-> WHEN removing duplicates / finding distinct categories")
counts = np.unique(np.array([1, 1, 2, 2, 3]), return_counts=True)
print("np.unique(return_counts=True):", counts, "-> WHEN you need a frequency count, like value_counts()")


