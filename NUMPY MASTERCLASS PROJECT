section("3. ARRAY ATTRIBUTES (properties, not methods - no parentheses)")
"""
WHAT: Attributes describe an array's metadata - shape, size, memory layout.
WHY:  Before operating on data you often need to know its dimensions/type
      to write correct code (e.g. matching shapes for matrix multiply).
WHEN: Use them constantly for debugging, validation, and writing
      shape-agnostic reusable code.
"""

arr = np.array([[1, 2, 3], [4, 5, 6]])

print("arr:\n", arr)
print("arr.ndim     :", arr.ndim, " -> number of dimensions/axes")
print("arr.shape    :", arr.shape, " -> tuple of length along each dimension")
print("arr.size     :", arr.size, " -> total number of elements (product of shape)")
print("arr.dtype    :", arr.dtype, " -> data type of elements (int64, float32, etc.)")
print("arr.itemsize :", arr.itemsize, " -> bytes consumed by ONE element")
print("arr.nbytes   :", arr.nbytes, " -> total bytes consumed by all elements (itemsize*size)")
print("arr.T        :\n", arr.T, " -> transposed view (rows<->columns)")
print("arr.flat     :", list(arr.flat), " -> 1D iterator over all elements")
print("arr.data     :", arr.data, " -> buffer object pointing to raw memory (rarely used directly)")
print("arr.flags    :\n", arr.flags, " -> memory layout info (C-contig, F-contig, owns data, writeable)")

# WHY dtype matters: choosing the smallest sufficient dtype saves huge memory at scale
small = np.array([1, 2, 3], dtype=np.int8)
big = np.array([1, 2, 3], dtype=np.int64)
print(f"\nint8 array nbytes: {small.nbytes} vs int64 array nbytes: {big.nbytes}")
print("-> WHEN working with millions of rows (e.g. images, ML datasets), pick tight dtypes to save RAM.")


