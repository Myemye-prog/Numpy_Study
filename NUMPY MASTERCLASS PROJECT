# 12. SAVING & LOADING (Array I/O)
# ==============================================================================
section("12. SAVING & LOADING ARRAYS (persistence)")
"""
WHAT: Functions to write arrays to disk and read them back.
WHY:  Data/results need to persist across program runs or be shared with
      other tools (Excel, pandas, other scripts).
WHEN: .npy/.npz for fast NumPy-native binary storage (WHEN working purely
      in Python/NumPy); .txt/.csv for human-readable / cross-tool sharing.
"""

sample = np.array([[1, 2, 3], [4, 5, 6]])

np.save("/tmp/sample.npy", sample)                       # WHAT: save single array in NumPy's own binary format
loaded = np.load("/tmp/sample.npy")                       # WHAT: load it back
print("np.save/np.load (.npy binary)   :\n", loaded, "-> WHEN you need fast, exact round-trip storage of one array")

np.savez("/tmp/multi.npz", a=sample, b=sample * 2)        # WHAT: save MULTIPLE named arrays in one file
loaded_multi = np.load("/tmp/multi.npz")
print("np.savez (.npz multi-array)     :", dict(loaded_multi).keys(), "-> WHEN bundling several related arrays together")

np.savetxt("/tmp/sample.csv", sample, delimiter=",", fmt="%d")   # WHAT: save as human-readable text/CSV
loaded_txt = np.loadtxt("/tmp/sample.csv", delimiter=",")
print("np.savetxt/np.loadtxt (.csv)    :\n", loaded_txt, "-> WHEN you need a format readable by Excel/other tools")


