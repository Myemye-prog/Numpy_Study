section("6. ARITHMETIC OPERATIONS & UFUNCS")
"""
WHAT: Element-wise math operations, executed in compiled C loops (ufuncs).
WHY:  Avoids explicit Python loops - the core reason NumPy is fast.
WHEN: Any elementwise math: physics simulations, normalizing data,
      applying formulas across a dataset, etc.
"""

x = np.array([1, 2, 3, 4])
y = np.array([10, 20, 30, 40])

print("x + y  :", x + y, "  (or np.add(x,y))")
print("x - y  :", x - y, "  (np.subtract)")
print("x * y  :", x * y, "  (np.multiply)  -> element-wise, NOT matrix multiply")
print("x / y  :", x / y, "  (np.divide)")
print("x ** 2 :", x ** 2, "  (np.power)")
print("x % 3  :", x % 3, "  (np.mod)")
print("np.sqrt(x)  :", np.sqrt(x), "-> WHEN needing square roots elementwise")
print("np.exp(x)   :", np.exp(x), "-> WHEN needing e^x, e.g. softmax/growth models")
print("np.log(x)   :", np.log(x), "-> WHEN needing natural log, e.g. log-loss, entropy")
print("np.abs(-x)  :", np.abs(-x), "-> WHEN needing absolute values")
print("np.round(x/3,2):", np.round(x / 3, 2), "-> WHEN rounding to N decimal places for display/precision")
print("np.sin(x)   :", np.sin(x), "-> WHEN doing trigonometry/signal processing")


