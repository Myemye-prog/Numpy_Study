# 4. RESHAPING & MANIPULATION METHODS
# ==============================================================================
section("4. RESHAPING & MANIPULATION METHODS")
"""
WHAT: Change an array's shape/dimensions/arrangement, without necessarily
      changing its data.
WHY:  Data often arrives in one shape (e.g. flat list) but algorithms need
      another (e.g. a matrix, a batch of images, a column vector).
WHEN: Any time input shape != required shape for the next computation/API.
"""

base = np.arange(12)
print("base:", base)

r1 = base.reshape(3, 4)                 # WHAT: reinterpret data in new shape (same total elements)
print("reshape(3,4):\n", r1, "\n-> WHEN converting flat data into a matrix/tensor form")

r2 = base.reshape(3, -1)                # -1 tells NumPy to auto-calculate that dimension
print("reshape(3,-1) auto dim:\n", r2)

r3 = r1.flatten()                       # WHAT: returns a 1D COPY of the array
print("flatten():", r3, "-> WHEN you need a 1D copy and want to safely modify it without affecting original")

r4 = r1.ravel()                         # WHAT: returns a 1D VIEW (no copy, if possible) - faster
print("ravel():", r4, "-> WHEN you need a 1D version fast and don't need it independent from original")

r5 = r1.T                               # transpose (swap axes)
print("transpose (.T):\n", r5)

r6 = np.transpose(r1, axes=(1, 0))      # explicit axes control (useful for >2D tensors)
print("np.transpose with axes:\n", r6)

r7 = np.swapaxes(r1, 0, 1)              # WHAT: swap two specific axes (useful for 3D+ arrays, e.g. images)
print("swapaxes(0,1):\n", r7)

r8 = r1.resize(2, 6)                    # WHAT: reshape IN-PLACE, can change total size (pads with 0/truncates)
print("resize(2,6) in-place:\n", r1, "-> WHEN you want to permanently alter array shape/size without new variable")

a = np.array([1, 2, 3])
b = np.array([4, 5, 6])
print("\nconcatenate:", np.concatenate([a, b]), "-> WHEN joining arrays along an EXISTING axis")
print("stack       :\n", np.stack([a, b]), "-> WHEN joining arrays along a NEW axis (creates higher dimension)")
print("vstack      :\n", np.vstack([a, b]), "-> WHEN stacking rows vertically (2D result)")
print("hstack      :", np.hstack([a, b]), "-> WHEN stacking horizontally (same axis as concatenate for 1D)")
print("column_stack:\n", np.column_stack([a, b]), "-> WHEN turning 1D arrays into columns of a 2D array")

split_arr = np.arange(9)
print("\nsplit into 3:", np.split(split_arr, 3), "-> WHEN dividing an array into N EQUAL parts")
print("array_split(4):", np.array_split(np.arange(10), 3), "-> WHEN dividing into N parts that need NOT be equal")

print("\nexpand_dims:", np.expand_dims(a, axis=0).shape, "-> WHEN you need to add a dimension (e.g. batch dim for ML)")
print("squeeze:", np.array([[[1, 2, 3]]]).squeeze().shape, "-> WHEN removing dimensions of size 1")


# ==============================================================================
# 5. INDEXING & SLICING
# ==============================================================================
section("5. INDEXING & SLICING")
"""
WHAT: Ways to access/select elements or sub-arrays.
WHY:  Real work needs specific rows/columns/conditions, not the whole array.
WHEN: Basic slicing for contiguous ranges; fancy/boolean indexing for
      scattered or conditional selection.
"""

m = np.arange(1, 26).reshape(5, 5)
print("matrix:\n", m)

print("\nBasic indexing m[1,2]     :", m[1, 2], "-> single element at row1,col2")
print("Row slice m[1]            :", m[1], "-> WHEN you need an entire row")
print("Column slice m[:,2]       :", m[:, 2], "-> WHEN you need an entire column")
print("Sub-matrix m[1:3, 2:4]    :\n", m[1:3, 2:4], "-> WHEN you need a rectangular block")
print("Reverse m[::-1]           :\n", m[::-1], "-> WHEN reversing row order (step = -1)")

# Fancy indexing - select using lists/arrays of indices (NOT contiguous)
idx = [0, 2, 4]
print("\nFancy indexing m[idx]     :\n", m[idx], "-> WHEN selecting arbitrary/non-contiguous rows")
print("Fancy m[idx, idx]         :", m[idx, idx], "-> WHEN selecting specific (row,col) pairs")

# Boolean indexing / masking - select using a condition
mask = m % 2 == 0
print("\nBoolean mask (m%2==0):\n", mask)
print("m[mask] (even numbers)    :", m[mask], "-> WHEN filtering elements by a CONDITION, very common in data cleaning")

m[m > 20] = 0   # assignment via boolean mask
print("After m[m>20]=0:\n", m, "-> WHEN you need to REPLACE values matching a condition")


