# 9. LINEAR ALGEBRA
# ==============================================================================
section("9. LINEAR ALGEBRA (np.linalg + matrix ops)")
"""
WHAT: Matrix-specific operations - different from element-wise math.
WHY:  Needed for ML (weights*inputs), graphics, physics, optimization,
      solving systems of equations.
WHEN: Whenever "matrix multiply", "solve for x", "invert", or
      "eigenvalues" comes up - NOT the same as `*` (which is element-wise).
"""

A = np.array([[1, 2], [3, 4]])
B = np.array([[5, 6], [7, 8]])

print("A @ B (matmul)     :\n", A @ B, "-> WHEN doing TRUE matrix multiplication (rows . columns)")
print("np.dot(A,B)        :\n", np.dot(A, B), "-> same result, alternate syntax; also works for vector dot product")
print("np.linalg.det(A)   :", np.linalg.det(A), "-> determinant, WHEN checking if a matrix is invertible (non-zero)")
print("np.linalg.inv(A)   :\n", np.linalg.inv(A), "-> WHEN solving linear systems / reversing a transform")
print("np.linalg.eig(A)   :", np.linalg.eig(A), "-> eigenvalues/vectors, WHEN doing PCA, stability analysis, etc.")

coeffs = np.array([[3, 1], [1, 2]])
consts = np.array([9, 8])
solution = np.linalg.solve(coeffs, consts)
print("np.linalg.solve()  :", solution, "-> WHEN solving Ax=b directly (faster/more stable than computing inverse)")

v = np.array([3, 4])
print("np.linalg.norm(v)  :", np.linalg.norm(v), "-> vector magnitude/length, WHEN measuring distance (Euclidean norm)")


