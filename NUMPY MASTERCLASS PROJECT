# 8. SORTING & SEARCHING
# ==============================================================================
section("8. SORTING & SEARCHING")
"""
WHAT: Order elements or locate values/positions matching a condition.
WHY:  Ranking, top-N queries, and conditional lookups are everywhere.
WHEN: sort() for order; argsort() when you need the ORIGINAL index order;
      where()/nonzero() for conditional searches.
"""

s = np.array([3, 1, 4, 1, 5, 9, 2, 6])
print("original     :", s)
print("np.sort(s)   :", np.sort(s), "-> returns a SORTED COPY")
print("s.sort()     :", (s.sort(), s)[1], "-> sorts IN-PLACE (modifies original, saves memory)")

s2 = np.array([3, 1, 4, 1, 5])
print("\nargsort(s2)  :", np.argsort(s2), "-> WHEN you need indices that WOULD sort the array (keep track of original order)")
print("s2[argsort]  :", s2[np.argsort(s2)])

print("\nwhere(s2>2)  :", np.where(s2 > 2), "-> returns INDICES where condition is True")
print("where as if-else:", np.where(s2 > 2, "big", "small"), "-> WHEN doing vectorized if-else replacement")
print("nonzero()    :", np.nonzero(s2), "-> WHEN finding indices of all non-zero (or True) entries")
print("searchsorted :", np.searchsorted(np.sort(s2), 3), "-> WHEN inserting into a SORTED array efficiently (binary search)")


