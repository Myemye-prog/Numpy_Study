# 2. ARRAY CREATION
# ==============================================================================
section("2. ARRAY CREATION FUNCTIONS")
"""
WHAT: Multiple ways to build an ndarray.
WHY:  Different situations need different starting points — from raw data,
      placeholders, ranges, or special matrices.
WHEN: Pick based on what you already have (a list? need zeros? need a range?).
"""

a1 = np.array([1, 2, 3, 4])                  # from a Python list -> WHEN: you already have data
a2 = np.array([[1, 2], [3, 4]])              # 2D array (matrix)
a3 = np.zeros((2, 3))                        # WHEN: need a placeholder array of 0s (e.g. init weights/accumulators)
a4 = np.ones((3, 3))                         # WHEN: need a placeholder of 1s (e.g. multiplicative identity base)
a5 = np.full((2, 2), 7)                      # WHEN: need a constant-filled array
a6 = np.empty((2, 2))                        # WHEN: need fast allocation, will overwrite values immediately (uninitialized/garbage memory - risky!)
a7 = np.arange(0, 10, 2)                     # WHEN: need evenly spaced ints/floats by STEP SIZE (like Python range)
a8 = np.linspace(0, 1, 5)                    # WHEN: need N evenly spaced points between two values (e.g. plotting x-axis)
a9 = np.eye(3)                                # WHEN: need an identity matrix (linear algebra, e.g. solving equations)
a10 = np.identity(3)                          # same as eye for square case
a11 = np.diag([1, 2, 3])                      # WHEN: need a diagonal matrix from a list of values
a12 = np.random.rand(2, 2)                    # WHEN: need random floats in [0,1) - uniform distribution
a13 = np.random.randn(2, 2)                   # WHEN: need random floats from standard normal distribution
a14 = np.random.randint(0, 10, (2, 3))        # WHEN: need random integers in a range
a15 = np.zeros_like(a2)                       # WHEN: need zeros with SAME shape/dtype as existing array
a16 = np.ones_like(a2)                        # same idea but filled with 1
a17 = np.full_like(a2, 9)                     # same idea but filled with a constant

print("np.array from list:\n", a1)
print("np.array 2D:\n", a2)
print("np.zeros((2,3)):\n", a3)
print("np.ones((3,3)):\n", a4)
print("np.full((2,2),7):\n", a5)
print("np.arange(0,10,2):", a7)
print("np.linspace(0,1,5):", a8)
print("np.eye(3):\n", a9)
print("np.diag([1,2,3]):\n", a11)
print("np.random.randint example:\n", a14)


