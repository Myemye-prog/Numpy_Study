import numpy as np

# Sudoku board
s = np.array([
    [5, 3, 4, 6, 7, 8, 9, 1, 2],
    [6, 7, 2, 1, 9, 5, 3, 4, 8],
    [1, 9, 8, 3, 4, 2, 5, 6, 7],
    [8, 5, 9, 7, 6, 1, 4, 2, 3],
    [4, 2, 6, 8, 5, 3, 7, 9, 1],
    [7, 1, 3, 9, 2, 4, 8, 5, 6],
    [9, 6, 1, 5, 3, 7, 2, 8, 4],
    [2, 8, 7, 4, 1, 9, 6, 3, 5],
    [3, 4, 5, 2, 8, 6, 1, 7, 9]
])

def valid_sudoku(board):
    """
    Returns True if the Sudoku board is valid.
    """

    # Valid Sudoku numbers must be exactly 1 to 9.
    valid = np.arange(1, 10)

    # -------------------------
    # Check every row
    # -------------------------
    for row in board:

        # Sort the row and compare with [1,2,3,4,5,6,7,8,9]
        if not np.array_equal(np.sort(row), valid):
            return False

    # -------------------------
    # Check every column
    # -------------------------
    for col in board.T:        # board.T gives transpose (columns become rows)

        if not np.array_equal(np.sort(col), valid):
            return False

    # -------------------------
    # Check every 3×3 subgrid
    # -------------------------
    for i in range(0, 9, 3):      # 0,3,6
        for j in range(0, 9, 3):  # 0,3,6

            # Extract one 3×3 block
            block = board[i:i+3, j:j+3]

            # Convert 3×3 block into 1D array
            block = block.ravel()

            # Check whether block contains numbers 1-9
            if not np.array_equal(np.sort(block), valid):
                return False

    # If every test passed
    return True


print(valid_sudoku(s))
