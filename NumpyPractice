import numpy as np

# ------------------------------------------------------------
# 1. Create a 1D Array
# Creates a simple one-dimensional array.
# ------------------------------------------------------------
print("\n1. Create 1D Array")
arr = np.array([10, 20, 30, 40, 50])
print(arr)

# ------------------------------------------------------------
# 2. Create a 2D Array
# Creates an array with rows and columns.
# ------------------------------------------------------------
print("\n2. Create 2D Array")
arr = np.array([[1, 2], [3, 4]])
print(arr)

# ------------------------------------------------------------
# 3. Array Dimensions
# Finds the number of dimensions.
# ------------------------------------------------------------
print("\n3. Array Dimension")
print(arr.ndim)

# ------------------------------------------------------------
# 4. Array Shape
# Returns rows and columns.
# ------------------------------------------------------------
print("\n4. Array Shape")
print(arr.shape)

# ------------------------------------------------------------
# 5. Array Size
# Total number of elements.
# ------------------------------------------------------------
print("\n5. Array Size")
print(arr.size)

# ------------------------------------------------------------
# 6. Data Type
# Shows the data type.
# ------------------------------------------------------------
print("\n6. Data Type")
print(arr.dtype)

# ------------------------------------------------------------
# 7. Zeros Array
# Creates an array filled with 0.
# ------------------------------------------------------------
print("\n7. Zeros")
print(np.zeros((2, 3)))

# ------------------------------------------------------------
# 8. Ones Array
# Creates an array filled with 1.
# ------------------------------------------------------------
print("\n8. Ones")
print(np.ones((3, 2)))

# ------------------------------------------------------------
# 9. Full Array
# Creates an array with the same value.
# ------------------------------------------------------------
print("\n9. Full")
print(np.full((2, 2), 7))

# ------------------------------------------------------------
# 10. Identity Matrix
# Creates an identity matrix.
# ------------------------------------------------------------
print("\n10. Identity Matrix")
print(np.eye(3))

# ------------------------------------------------------------
# 11. Range Array
# Creates numbers using arange().
# ------------------------------------------------------------
print("\n11. Arange")
print(np.arange(1, 11))

# ------------------------------------------------------------
# 12. Even Numbers
# Creates even numbers.
# ------------------------------------------------------------
print("\n12. Even Numbers")
print(np.arange(2, 21, 2))

# ------------------------------------------------------------
# 13. Linspace
# Creates equally spaced values.
# ------------------------------------------------------------
print("\n13. Linspace")
print(np.linspace(1, 10, 5))

# ------------------------------------------------------------
# 14. Reshape Array
# Changes array shape.
# ------------------------------------------------------------
print("\n14. Reshape")
arr = np.arange(1, 13)
print(arr.reshape(3, 4))

# ------------------------------------------------------------
# 15. Flatten Array
# Converts 2D to 1D.
# ------------------------------------------------------------
print("\n15. Flatten")
a = np.array([[1, 2], [3, 4]])
print(a.flatten())

# ------------------------------------------------------------
# 16. Maximum Value
# Finds largest element.
# ------------------------------------------------------------
print("\n16. Maximum")
print(np.max(a))

# ------------------------------------------------------------
# 17. Minimum Value
# Finds smallest element.
# ------------------------------------------------------------
print("\n17. Minimum")
print(np.min(a))

# ------------------------------------------------------------
# 18. Sum
# Finds total sum.
# ------------------------------------------------------------
print("\n18. Sum")
print(np.sum(a))

# ------------------------------------------------------------
# 19. Mean
# Finds average.
# ------------------------------------------------------------
print("\n19. Mean")
print(np.mean(a))

# ------------------------------------------------------------
# 20. Median
# Finds middle value.
# ------------------------------------------------------------
print("\n20. Median")
print(np.median(a))

# ------------------------------------------------------------
# 21. Standard Deviation
# Measures spread of data.
# ------------------------------------------------------------
print("\n21. Standard Deviation")
print(np.std(a))

# ------------------------------------------------------------
# 22. Sort Array
# Sorts elements.
# ------------------------------------------------------------
print("\n22. Sort")
arr = np.array([7, 3, 9, 2, 1])
print(np.sort(arr))

# ------------------------------------------------------------
# 23. Unique Values
# Removes duplicate values.
# ------------------------------------------------------------
print("\n23. Unique")
arr = np.array([1, 2, 2, 3, 4, 4, 5])
print(np.unique(arr))

# ------------------------------------------------------------
# 24. Search Element
# Finds index of an element.
# ------------------------------------------------------------
print("\n24. Search")
print(np.where(arr == 4))

# ------------------------------------------------------------
# 25. Boolean Indexing
# Filters values greater than 3.
# ------------------------------------------------------------
print("\n25. Boolean Indexing")
print(arr[arr > 3])

# ------------------------------------------------------------
# 26. Add Two Arrays
# Performs element-wise addition.
# ------------------------------------------------------------
print("\n26. Addition")
a = np.array([1, 2, 3])
b = np.array([4, 5, 6])
print(a + b)

# ------------------------------------------------------------
# 27. Multiply Two Arrays
# Performs element-wise multiplication.
# ------------------------------------------------------------
print("\n27. Multiplication")
print(a * b)

# ------------------------------------------------------------
# 28. Matrix Multiplication
# Multiplies two matrices.
# ------------------------------------------------------------
print("\n28. Matrix Multiplication")
x = np.array([[1, 2], [3, 4]])
y = np.array([[5, 6], [7, 8]])
print(np.dot(x, y))

# ------------------------------------------------------------
# 29. Transpose Matrix
# Swaps rows and columns.
# ------------------------------------------------------------
print("\n29. Transpose")
print(x.T)

# ------------------------------------------------------------
# 30. Random Numbers
# Generates random integers.
# ------------------------------------------------------------
print("\n30. Random Numbers")
print(np.random.randint(1, 101, 10))

print("\n========== End of NumPy Practice ==========")
